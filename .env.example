# ── Qdrant ────────────────────────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=medquad_chunks

# ── Embedding ─────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIM=384

# ── Chunking ──────────────────────────────────────────────────────────────────
CHUNK_SIZE=400
CHUNK_OVERLAP=50
EMBEDDING_BATCH_SIZE=64

# ── Retrieval ─────────────────────────────────────────────────────────────────
TOP_K=5

# ── LLM (Ollama) ──────────────────────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
LLM_MODEL=llama3.1:8b
LLM_MAX_TOKENS=2048

# ── Dataset ───────────────────────────────────────────────────────────────────
HF_DATASET_NAME=lavita/medical-qa-datasets
HF_DATASET_SPLIT=train

# ── App ───────────────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
