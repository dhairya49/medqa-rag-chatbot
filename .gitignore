# ── Environment ───────────────────────────────────────────────────────────────
.env
!.env.example

# ── Python virtual environment ────────────────────────────────────────────────
venv/

# ── Python cache ──────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# ── Distribution / packaging ──────────────────────────────────────────────────
dist/
build/
*.egg-info/
*.egg

# ── Logs ──────────────────────────────────────────────────────────────────────
logs/
*.log

# ── Qdrant local storage (if running outside Docker) ─────────────────────────
qdrant_storage/
.qdrant/

# ── Hugging Face cache (if ever downloaded inside project) ───────────────────
.cache/
hf_cache/

# ── Jupyter notebooks checkpoints ────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Testing ───────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Docker ────────────────────────────────────────────────────────────────────
.dockerignore

# ── Misc ──────────────────────────────────────────────────────────────────────
*.tmp
*.bak